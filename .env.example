# Dataset
DATASET_NAME=arxiv
DATASET_DOMAIN=research
DATASET_SOURCE_URL=https://arxiv.org/
DATASET_VERSION=1.0.0
ARXIV_QUERY=cat:cs.AI
ARXIV_START=0
ARXIV_MAX_RESULTS=2000
ARXIV_PAGE_SIZE=100
ARXIV_MAX_PAGES=0
ARXIV_REQUEST_DELAY_SECONDS=0.25
ARXIV_DEDUP_IN_RUN=true
ARXIV_RETRY_ATTEMPTS=5
ARXIV_RETRY_BACKOFF_SECONDS=1.0
ARXIV_RETRY_BACKOFF_FACTOR=2.0
ARXIV_FAIL_FAST=false
ARXIV_SORT_BY=submittedDate
ARXIV_SORT_ORDER=descending

# Pipeline
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# LLM / Embeddings
OLLAMA_LLM_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# Infra defaults
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpass
POSTGRES_DB=ragdb
